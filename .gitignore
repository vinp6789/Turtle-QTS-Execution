# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Test / tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Editor / OS noise
.vscode/
.idea/
*.swp
.DS_Store

# Local event-store data (runtime logs written by EventStore)
*.log

# Productization: runtime state, secrets, scratch
data/
.env
.env.*
!.env.example
# Plaintext secrets file kept locally as `env` (no dot): the `env/` rule
# above matches only a DIRECTORY, so the file must be ignored explicitly.
env
scratchpad/
