# Copy to .env and fill in. NEVER commit a real .env.
# Every value has a safe default EXCEPT the signing secret; the app boots in
# paper mode with only the signing secret set.

# ---- required (paper & live) ----
# Signing key material for the Turtle authorization boundary (any non-empty
# string works in paper mode; a real HMAC secret in production).
TURTLE_SECRET_HYPERLIQUID_SIGNING_KEY_V1=change-me-paper-secret

# ---- engine selection ----
ENGINE_CONFIG_PATH=deploy/engine.paper.toml
ENGINE_STORE_PATH=data/events.log

# ---- required for LIVE trading only ----
# Public venue wallet address (NOT a secret). Required when engine mode=live.
# TURTLE_DEPLOYMENT_ACCOUNT_ADDRESS=0xYourWalletAddress
# Wallet signing key for EIP-712 (secp256k1). Required for live mutations.
# TURTLE_SECRET_HYPERLIQUID_WALLET_KEY_V1=0xYourPrivateKey
# TURTLE_ENGINE_VERSION=1.0.0

# ---- HTTP server ----
APP_HOST=0.0.0.0
APP_PORT=8000
# Railway injects PORT automatically; it overrides APP_PORT.

# ---- background worker ----
WORKER_ENABLED=true
CYCLE_INTERVAL_SECONDS=60

# ---- cycle / sizing parameters ----
CYCLE_MAINTENANCE_MARGIN_RATE=0.005
CYCLE_TARGET_LEVERAGE=1

# ---- portfolio equity seed (C1 fix) ----
# One-time deposit into the portfolio ledger, applied EXACTLY ONCE per
# event store (fixed idempotency id): restarts never double-deposit, and
# changing this value later has NO effect on an existing store. 0 disables.
# Without equity, RiskManager fail-safes every trade (nothing can be placed).
PORTFOLIO_INITIAL_DEPOSIT=0

# ---- risk limits (risk_manager.RiskManagerLimits) ----
RISK_MAX_LEVERAGE=10
RISK_MIN_LIQ_BUFFER_PCT=0.1
RISK_MAX_FUNDING_RATE_ABS=0.05
RISK_MAX_CORRELATED_POSITIONS=3
# MUST be greater than CYCLE_INTERVAL_SECONDS (validated at startup; boot
# fails fast otherwise): portfolio/position timestamps only advance on
# accounting events, so a staleness limit at or below the cycle interval
# would FAIL_SAFE every post-idle risk evaluation. Recommended >= 2x interval.
RISK_MAX_STALE_DATA_SECONDS=150

# ---- observability ----
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_ENABLED=true

# ---- security: gates /cycle/run and /control/emergency-stop ----
# FAIL-CLOSED: if this is unset (or whitespace), those control endpoints are
# DISABLED and return HTTP 503 -- no unauthenticated caller can run a cycle
# or trigger the one-way emergency stop. Read-only monitoring (/health,
# /status, /portfolio, /reports, /metrics) is always open regardless.
# SET THIS IN PRODUCTION to a strong secret to ENABLE the control endpoints;
# present it as `X-API-Key: <key>` or `Authorization: Bearer <key>`.
API_KEY=

# ---- dashboard ----
DASHBOARD_ENABLED=true

# ---- telegram (optional) ----
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
